# Port the server listens on
PORT=3000

# Human-readable name for this instance, shown in the UI so you can
# see which server you landed on behind the load balancer
INSTANCE_NAME=solo

# Redis connection URL. If unset, the server runs in single-instance
# mode (in-memory history, no cross-instance pub/sub).
REDIS_URL=redis://localhost:6379

# Anthropic API key for the AI chatbot. If unset, a local rule-based
# fallback bot answers instead, so the app works with zero config.
ANTHROPIC_API_KEY=

# Model used by the AI bot
BOT_MODEL=claude-opus-4-8
